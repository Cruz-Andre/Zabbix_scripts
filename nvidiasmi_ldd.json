{
    "zabbix_export": {
        "version": "7.4",
        "template_groups": [
            {
                "uuid": "a571c0d144b14fd4a87a9d9b2aa9fcd6",
                "name": "Templates/Applications"
            }
        ],
        "templates": [
            {
                "uuid": "db94ad0fe8dd4a6e825f5b104d468939",
                "template": "NVIDIA SMI",
                "name": "NVIDIA SMI",
                "description": "Usando o nvidia-smi.exe",
                "groups": [
                    {
                        "name": "Templates/Applications"
                    }
                ],
                "items": [
                    {
                        "uuid": "92951b8b703249cf938a62084adf45b6",
                        "name": "GPU Fan Speed",
                        "key": "gpu.fanspeed",
                        "units": "%",
                        "description": "Buscar em % o uso da ventoinha",
                        "triggers": [
                            {
                                "uuid": "8c0ac2995e8e4b74aa0736883a2f5c2e",
                                "expression": "last(/NVIDIA SMI/gpu.fanspeed)=0",
                                "name": "A ventoinha est\u00e1 parada no host: {HOST.NAME}",
                                "priority": "DISASTER",
                                "manual_close": "YES"
                            },
                            {
                                "uuid": "37ea0913002a41c4bd3610569d18bec6",
                                "expression": "last(/NVIDIA SMI/gpu.fanspeed)>{$FAN_SPEED}",
                                "name": "O uso da ventoinha est\u00e1 acima de {$FAN_SPEED}% no host: {HOST.NAME}",
                                "priority": "WARNING",
                                "description": "Alerta se a ventoinha passar de 33% de uso.",
                                "manual_close": "YES"
                            }
                        ]
                    },
                    {
                        "uuid": "5f0a69cb8c844b0b9fd3370c2e1bb259",
                        "name": "GPU Temperature",
                        "key": "gpu.temperature",
                        "units": "\u00baC",
                        "description": "Busca a temperatura da GPU em \u00baC",
                        "triggers": [
                            {
                                "uuid": "72a4d48853854ffd97ebd97a6dfd5e84",
                                "expression": "last(/NVIDIA SMI/gpu.temperature)>{$GPU_TEMP}",
                                "name": "A temperatura da GPU est\u00e1 acima de {$GPU_TEMP}\u00baC no host: {HOST.NAME}",
                                "priority": "HIGH",
                                "manual_close": "YES"
                            }
                        ]
                    },
                    {
                        "uuid": "f77ed270ab514a95b04ae7603e826211",
                        "name": "GPU Usage",
                        "key": "gpu.usage",
                        "units": "%",
                        "description": "Busca o uso da GPU em %",
                        "triggers": [
                            {
                                "uuid": "16fa39901197489d8a9469a01c17e10f",
                                "expression": "last(/NVIDIA SMI/gpu.usage)>={$GPU_USAGE}",
                                "name": "Uso da GPU est\u00e1 acima de {$GPU_USAGE}% no host: {HOST.NAME}",
                                "priority": "WARNING",
                                "manual_close": "YES"
                            }
                        ]
                    }
                ],
                "macros": [
                    {
                        "macro": "{$FAN_SPEED}",
                        "value": "40",
                        "description": "Velocidade da ventoinha em %"
                    },
                    {
                        "macro": "{$GPU_TEMP}",
                        "value": "40",
                        "description": "Temperatura da GPU em \u00baC"
                    },
                    {
                        "macro": "{$GPU_USAGE}",
                        "value": "40",
                        "description": "Uso da GPU em %"
                    }
                ]
            }
        ]
    }
}